# ── Backend (backend/.env) ────────────────────────────────────────────────────
#
# Supabase: vá em Project Settings > Database > Connection string > URI
# Troque [YOUR-PASSWORD] pela senha do banco (definida ao criar o projeto)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.<PROJECT-REF>.supabase.co:5432/postgres

# Chave secreta para assinar os tokens JWT
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=sua-chave-secreta-longa-e-aleatoria

# Validade do token em minutos (1440 = 24 horas)
JWT_EXPIRE_MINUTES=1440


# ── Frontend (frontend/.env) — opcional ──────────────────────────────────────
# VITE_API_URL=http://localhost:8000/api
